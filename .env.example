# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Authentication secrets — generate each with: openssl rand -hex 32
BETTER_AUTH_SECRET=
A2A_SECRET=

# Public URL of your Railway deployment (set after first deploy)
APP_URL=https://your-app.up.railway.app
BETTER_AUTH_URL=https://your-app.up.railway.app

# Database — Railway Postgres plugin sets this automatically
# Defaults to SQLite (data/app.db) if unset (not recommended for production)
DATABASE_URL=

# ─── Optional: Google OAuth (Gmail / Google Calendar integration) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Optional: GitHub OAuth ───────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Optional: Slack integration ─────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ─── Optional: OpenAI ─────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Optional: access control ────────────────────────────────────────────────
# Set to a secret token to require authentication on all routes
ACCESS_TOKEN=

# ─── Optional: background jobs ───────────────────────────────────────────────
# Set to "1" to enable background job processing
RUN_BACKGROUND_JOBS=1
